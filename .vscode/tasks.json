{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev server",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "ready in \\d+ ms|Local:\\s+http"
        }
      },
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
